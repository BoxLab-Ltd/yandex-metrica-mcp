# Authentication.
#
# Easiest: run `yandex-metrica-mcp auth` (no env needed) to sign in with your
# Yandex account via the built-in public OAuth client. The token is cached at
# ~/.config/yandex-metrica-mcp/token.json and a cached login takes precedence
# over the variables below.
#
# Static token (e.g. for CI): get one for an app with the `metrika:read` scope
# at https://oauth.yandex.ru and put it here.
YANDEX_METRIKA_TOKEN=

# Own OAuth app (optional): override the built-in client. Add the secret to also
# enable automatic token refresh.
# YANDEX_OAUTH_CLIENT_ID=
# YANDEX_OAUTH_CLIENT_SECRET=

# Default counter id (optional). When set, tools may omit `counterId`.
# YANDEX_METRIKA_COUNTER_ID=

# Response language for human-readable labels: en | ru | tr | ... (default: en)
# YANDEX_METRIKA_LANG=en

# Override the token cache location (optional).
# YANDEX_METRIKA_TOKEN_FILE=

# Directory for Logs API file exports (optional). `logs_download` with
# mode="file" writes here; defaults to a folder under the OS temp directory.
# YANDEX_METRIKA_LOGS_DIR=

# API / OAuth base URLs (optional, only override for testing/mocking).
# YANDEX_METRIKA_BASE_URL=https://api-metrika.yandex.net
# YANDEX_OAUTH_BASE_URL=https://oauth.yandex.com
